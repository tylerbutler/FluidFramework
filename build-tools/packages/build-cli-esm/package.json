{
	"name": "build-cli-esm",
	"version": "0.4.24",
	"description": "Fluid Framework build tools (ESM)",
	"keywords": ["oclif"],
	"homepage": "https://github.com/packages/build-cli-esm",
	"bugs": "https://github.com/packages/build-cli-esm/issues",
	"repository": "packages/build-cli-esm",
	"license": "MIT",
	"author": "Microsoft",
	"type": "module",
	"exports": "./lib/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"flub": "./bin/run.js"
	},
	"files": ["/bin", "/dist", "/oclif.manifest.json"],
	"scripts": {
		"build": "shx rm -rf dist && tsc -b",
		"lint": "eslint . --ext .ts",
		"prepack": "yarn build && oclif manifest && oclif readme",
		"postpack": "shx rm -f oclif.manifest.json",
		"prepare": "yarn build",
		"test": "mocha --forbid-only \"test/**/*.test.ts\"",
		"posttest": "yarn lint",
		"version": "oclif readme && git add README.md"
	},
	"oclif": {
		"bin": "flub",
		"commands": "./dist/commands",
		"dirname": "flub",
		"plugins": ["@oclif/plugin-help", "@oclif/plugin-plugins"],
		"topicSeparator": " ",
		"topics": {
			"hello": {
				"description": "Say hello to the world and others"
			}
		}
	},
	"dependencies": {
		"@oclif/core": "^3",
		"@oclif/plugin-help": "^6",
		"@oclif/plugin-plugins": "^4"
	},
	"devDependencies": {
		"@oclif/prettier-config": "^0.2.1",
		"@oclif/test": "^3",
		"@types/chai": "^4",
		"@types/mocha": "^10",
		"@types/node": "^18",
		"chai": "^4",
		"eslint": "^8",
		"eslint-config-oclif": "^5",
		"eslint-config-oclif-typescript": "^3",
		"eslint-config-prettier": "^9.1.0",
		"mocha": "^10",
		"oclif": "^4.5.4",
		"shx": "^0.3.4",
		"ts-node": "^10.9.2",
		"typescript": "^5"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
