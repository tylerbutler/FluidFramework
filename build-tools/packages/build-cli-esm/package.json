{
	"name": "@fluid-tools/build-cli-esm",
	"version": "0.0.0",
	"private": true,
	"description": "Plugin for ESM-only build-cli commands.",
	"homepage": "https://fluidframework.com",
	"bugs": "https://github.com/microsoft/FluidFramework/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "build-tools/packages/build-cli-esm"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"type": "module",
	"exports": "./lib/index.js",
	"types": "lib/index.d.ts",
	"bin": {
		"flub-esm": "./bin/run.js"
	},
	"files": [
		"/bin",
		"/lib",
		"/oclif.manifest.json"
	],
	"scripts": {
		"build": "concurrently npm:build:compile npm:lint && concurrently npm:build:docs npm:build:diagrams",
		"build:compile": "npm run tsc && npm run build:readme",
		"build:docs": "api-extractor run --local",
		"build:manifest": "oclif manifest",
		"build:readme": "fluid-readme generate readme --multi",
		"ci:build:docs": "api-extractor run",
		"clean": "rimraf --glob dist lib oclif.manifest.json \"**/*.tsbuildinfo\" \"**/*.build.log\" _api-extractor-temp nyc",
		"clean:manifest": "rimraf --glob oclif.manifest.json",
		"compile": "fluid-build . --task compile",
		"eslint": "eslint --format stylish src",
		"eslint:fix": "eslint --format stylish src --fix --fix-type problem,suggestion,layout",
		"format": "npm run prettier:fix",
		"lint": "npm run prettier && npm run eslint",
		"lint:fix": "npm run prettier:fix && npm run eslint:fix",
		"postpack": "npm run clean:manifest",
		"prettier": "prettier --check . --cache --ignore-path ../../../.prettierignore",
		"prettier:fix": "prettier --write . --cache --ignore-path ../../../.prettierignore",
		"test": "npm run test:mocha",
		"test:coverage": "c8 npm run test",
		"test:mocha": "mocha --forbid-only \"test/**/*.test.ts\"",
		"tsc": "tsc"
	},
	"dependencies": {
		"@fluid-tools/build-cli": "workspace:~",
		"@fluidframework/build-tools": "workspace:~",
		"@oclif/core": "^3.9.0",
		"@oclif/plugin-autocomplete": "^2.3.10",
		"@oclif/plugin-commands": "^3.0.4",
		"@oclif/plugin-help": "^6.0.4",
		"@oclif/plugin-not-found": "^3.0.2",
		"@oclif/plugin-plugins": "^4.1.8",
		"chalk": "^5.3.0",
		"publint": "^0.2.5"
	},
	"devDependencies": {
		"@fluid-private/readme-command": "workspace:~",
		"@fluidframework/build-common": "^2.0.3",
		"@fluidframework/eslint-config-fluid": "^3.1.0",
		"@oclif/prettier-config": "^0.2.1",
		"@oclif/test": "~3.1.2",
		"@types/chai": "^4.3.5",
		"@types/mocha": "^10.0.5",
		"@types/node": "^18.18.6",
		"chai": "^4.3.7",
		"eslint": "~8.51.0",
		"eslint-config-oclif": "^5.0.0",
		"eslint-config-oclif-typescript": "^3.0.8",
		"eslint-config-prettier": "~9.0.0",
		"mocha": "^10.2.0",
		"oclif": "^4.0.3",
		"shx": "^0.3.4",
		"ts-node": "^10.9.1",
		"typescript": "~5.1.6"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"oclif": {
		"bin": "flubx",
		"dirname": "flubx",
		"commands": "./lib/commands",
		"flexibleTaxonomy": true,
		"additionalHelpFlags": [
			"-h"
		],
		"additionalVersionFlags": [
			"-V"
		],
		"plugins": [
			"@fluid-tools/build-cli",
			"@oclif/plugin-autocomplete",
			"@oclif/plugin-commands",
			"@oclif/plugin-help",
			"@oclif/plugin-not-found"
		],
		"repositoryPrefix": "<%- repo %>/blob/main/build-tools/packages/build-cli-esm/<%- commandPath %>",
		"topicSeparator": " ",
		"topics": {
			"bump": {
				"description": "Bump the version of packages, release groups, and their dependencies."
			},
			"check": {
				"description": "Check commands are used to verify repo state, apply policy, etc."
			},
			"generate": {
				"description": "Generate commands are used to create/update code, docs, readmes, etc."
			},
			"release": {
				"description": "Release commands are used to manage the Fluid release process."
			}
		}
	}
}
