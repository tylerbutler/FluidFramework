{
	"name": "@fluid-tools/build-cli-esm",
	"version": "0.4.24",
	"private": true,
	"description": "Fluid Framework build tools (ESM)",
	"keywords": [
		"oclif"
	],
	"homepage": "https://fluidframework.com",
	"bugs": "https://github.com/packages/build-cli-esm/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/FluidFramework.git",
		"directory": "build-tools/packages/build-cli-esm"
	},
	"license": "MIT",
	"author": "Microsoft and contributors",
	"type": "module",
	"exports": "./lib/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"flub": "./bin/run.js"
	},
	"files": [
		"/bin",
		"/dist",
		"/oclif.manifest.json"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"lint": "eslint . --ext .ts",
		"postpack": "shx rm -f oclif.manifest.json",
		"test": "mocha --forbid-only \"test/**/*.test.ts\"",
		"tsc": "tsc -b"
	},
	"dependencies": {
    "@fluid-tools/build-cli": "workspace:~",
		"@oclif/core": "^3",
		"@oclif/plugin-help": "^6",
		"@oclif/plugin-plugins": "^4"
	},
	"devDependencies": {
		"@oclif/prettier-config": "^0.2.1",
		"@oclif/test": "^3",
		"@types/chai": "^4",
		"@types/mocha": "^10",
		"@types/node": "^18",
		"chai": "^4",
		"eslint": "^8",
		"eslint-config-oclif": "^5",
		"eslint-config-oclif-typescript": "^3",
		"eslint-config-prettier": "^9.1.0",
		"mocha": "^10",
		"oclif": "^4.5.4",
		"shx": "^0.3.4",
		"ts-node": "^10.9.2",
		"typescript": "^5"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"oclif": {
		"bin": "flub",
		"commands": "./dist/commands",
		"dirname": "flub",
		"plugins": [
			"@fluid-tools/build-cli",
			"@oclif/plugin-help",
			"@oclif/plugin-plugins"
		],
		"topicSeparator": " ",
		"topics": {
			"hello": {
				"description": "Say hello to the world and others"
			}
		}
	}
}
