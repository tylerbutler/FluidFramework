{
	"extends": [
		"../../../common/build/build-common/tsconfig.base.json",
		"../../../common/build/build-common/tsconfig.esm-only.json",
	],
	"include": ["src/**/*"],
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./lib",
