{
	"name": "@fluid-tools/sail",
	"version": "0.0.1",
	"private": true,
	"description": "Come sail away.",
	"keywords": [
		"build"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./lib/index.d.ts",
				"default": "./lib/index.js"
			}
		}
	},
	"types": "lib/index.d.ts",
	"bin": {
		"sail": "./bin/run.js"
	},
	"files": [
		"/bin",
		"/lib",
		"/oclif.manifest.json"
	],
	"scripts": {
		"build": "concurrently npm:build:compile npm:lint && concurrently npm:build:docs npm:build:diagrams",
		"build:compile": "npm run tsc && npm run build:test && npm run build:copy && npm run build:readme",
		"build:docs": "api-extractor run --local",
		"build:manifest": "oclif manifest",
		"build:readme": "oclif readme --version 0.0.0 --multi --no-aliases",
		"check": "npm run check:format",
		"check:format": "biome format .",
		"clean": "rimraf --glob dist lib oclif.manifest.json \"**/*.tsbuildinfo\" \"**/*.build.log\" _api-extractor-temp nyc",
		"clean:manifest": "rimraf --glob oclif.manifest.json",
		"compile": "fluid-build . --task compile",
		"eslint": "eslint --format stylish src",
		"eslint:fix": "eslint --format stylish src --fix --fix-type problem,suggestion,layout",
		"format": "npm run format:biome",
		"format:biome": "biome check --write .",
		"lint": "npm run eslint",
		"lint:fix": "npm run eslint:fix",
		"postpack": "npm run clean:manifest",
		"test": "npm run test:mocha",
		"test:coverage": "c8 npm run test",
		"test:mocha": "mocha --forbid-only \"test/**/*.test.ts\"",
		"tsc": "tsc"
	},
	"dependencies": {
		"@fluid-tools/build-cli": "workspace:^",
		"@fluidframework/build-tools": "workspace:^",
		"@oclif/core": "^4.0.14",
		"@oclif/plugin-autocomplete": "^3.1.9",
		"@oclif/plugin-help": "^6.2.7",
		"@oclif/plugin-plugins": "^5.2.4",
		"@oclif/plugin-warn-if-update-available": "^3.1.5",
		"chalk": "^5.3.0",
		"concurrently": "^8.2.1",
		"cosmiconfig": "^8.2.0",
		"debug": "^4.3.4",
		"simple-git": "^3.19.1",
		"strip-ansi": "^6.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "~1.8.3",
		"@oclif/test": "^3.2.12",
		"@types/async": "^3.2.20",
		"@types/chai": "^4.3.5",
		"@types/debug": "^4.1.7",
		"@types/mocha": "^9.1.1",
		"@types/node": "^18.18.6",
		"chai": "^4.3.7",
		"eslint": "~8.57.0",
		"eslint-config-oclif": "^5.2.0",
		"eslint-config-oclif-typescript": "^3.1.8",
		"eslint-config-prettier": "~9.1.0",
		"mocha": "^10.2.0",
		"oclif": "^4.14.9",
		"rimraf": "^4.4.1",
		"sort-package-json": "1.57.0",
		"ts-node": "^10.9.1",
		"tslib": "^2.6.0",
		"type-fest": "^2.19.0",
		"typescript": "~5.4.5"
	},
	"oclif": {
		"additionalHelpFlags": [
			"-h"
		],
		"additionalVersionFlags": [
			"-V"
		],
		"bin": "sail",
		"commands": "./lib/commands",
		"dirname": "sail-cli",
		"plugins": [
			"@oclif/plugin-help",
			"@oclif/plugin-autocomplete",
			"@oclif/plugin-warn-if-update-available"
		],
		"repositoryPrefix": "<%- repo %>/blob/main/packages/sail/<%- commandPath %>",
		"topicSeparator": " ",
		"topics": {}
	}
}
